# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vibeopenclaw
DB_USER=voc
DB_PASSWORD=YOUR_PASSWORD_HERE

# Security
JWT_SECRET=YOUR_JWT_SECRET_HERE
ENCRYPTION_KEY=YOUR_ENCRYPTION_KEY_HERE

# Polar.sh (billing)
POLAR_ACCESS_TOKEN=polar_pat_...
POLAR_WEBHOOK_SECRET=whsec_...
