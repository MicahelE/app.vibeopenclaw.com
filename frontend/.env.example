# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vibeopenclaw
DB_USER=voc
DB_PASSWORD=YOUR_PASSWORD_HERE

# Security
JWT_SECRET=YOUR_JWT_SECRET_HERE
ENCRYPTION_KEY=YOUR_ENCRYPTION_KEY_HERE

# Polar.sh (billing)
POLAR_ENVIRONMENT=sandbox
POLAR_ACCESS_TOKEN=YOUR_POLAR_ACCESS_TOKEN
POLAR_WEBHOOK_SECRET=YOUR_POLAR_WEBHOOK_SECRET
POLAR_PRODUCT_PRO=YOUR_POLAR_PRODUCT_PRO_ID
POLAR_PRODUCT_PREMIUM=YOUR_POLAR_PRODUCT_PREMIUM_ID

# App
NEXT_PUBLIC_APP_URL=https://app.vibeopenclaw.com

# Docker
AGENT_NETWORK=voc-agents
DATA_DIR=/opt/vibeopenclaw/data/agents
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
HERMES_IMAGE=hermes-agent:latest