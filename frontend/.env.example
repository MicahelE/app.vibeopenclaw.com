POLAR_PRODUCT_PREMIUM=...

# App
NEXT_PUBLIC_APP_URL=https://app.vibeopenclaw.com

# Docker
AGENT_NETWORK=voc-agents
DATA_DIR=/opt/vibeopenclaw/data/agents